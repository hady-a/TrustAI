# Docker Environment Configuration Example
# Copy this as .env in each service directory

# ============================================
# Backend Configuration (.env in apps/backend/)
# ============================================
NODE_ENV=development
PORT=5000
LOG_LEVEL=info

# Database - communicates with postgres service
# Use 'postgres' as hostname since they're on same Docker network
DATABASE_URL=postgres://trustai_user:trustai_password@postgres:5432/trustai

# Redis - communicates with redis service
# Use 'redis' as hostname since they're on same Docker network
REDIS_URL=redis://redis:6379

# JWT Configuration
JWT_SECRET=your-secret-key-here-change-in-production
JWT_EXPIRY=7d

# Optional: OAuth configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Optional: Email configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
SMTP_FROM=noreply@trustai.com

# ============================================
# Frontend Configuration (.env in apps/frontend/)
# ============================================

# API URLs - inside Docker use service names
# Outside Docker (from browser) use localhost
VITE_API_URL=http://localhost:5000
VITE_AI_SERVICE_URL=http://localhost:8000

# Optional: Analytics
VITE_ANALYTICS_ID=your-analytics-id

# ============================================
# AI Service Configuration (.env in apps/ai-service/)
# ============================================

# Python environment
PYTHONUNBUFFERED=1
LOG_LEVEL=info

# Optional: AI Model configuration
MODEL_PATH=/app/models/
BATCH_SIZE=32
DEVICE=cpu  # or 'cuda' for GPU

# Optional: External API keys
OPENAI_API_KEY=your-key-here
HUGGING_FACE_API_KEY=your-key-here

# ============================================
# Docker Compose Database Credentials
# ============================================
# These are set in docker-compose.yml
# Keep in sync!

# POSTGRES_USER=trustai_user
# POSTGRES_PASSWORD=trustai_password
# POSTGRES_DB=trustai

# For development, you can use these:
# DB_HOST=postgres (Docker hostname)
# DB_PORT=5432
# DB_NAME=trustai
# DB_USER=trustai_user
# DB_PASSWORD=trustai_password
