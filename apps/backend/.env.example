# ============================================
# TrustAI Backend Environment Configuration
# ============================================
# Copy this file to .env and update values

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=9999
NODE_ENV=development

# ============================================
# DATABASE CONFIGURATION
# ============================================
# PostgreSQL Connection String
# Format: postgresql://[user[:password]@][ip/hostname]:[port]/[db_name]
# 
# Local example:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trustai
#
# Docker example:
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/trustai
#
# Cloud example (Supabase/Railway):
# DATABASE_URL=postgresql://user:password@host.region.db/dbname

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trustai

# ============================================
# REDIS CONFIGURATION (for job queue)
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# AUTHENTICATION
# ============================================
# JWT Secret - Generate a secure key with: openssl rand -base64 32
JWT_SECRET=your-secret-key-change-in-production

# ============================================
# GOOGLE OAUTH
# ============================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:9999/api/auth/google/callback

# ============================================
# API KEYS (Optional for external services)
# ============================================
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=...

# ============================================
# FILE UPLOAD
# ============================================
# Maximum file size in MB
MAX_FILE_SIZE=100

# ============================================
# SECURITY
# ============================================
# Session timeout in milliseconds (default: 900000 = 15 minutes)
SESSION_TIMEOUT=900000

# ============================================
# LOGGING
# ============================================
# Log level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# ============================================
# CORS
# ============================================
# Allowed origins (comma-separated)
CORS_ORIGIN=http://localhost:3000

# ============================================
# DEVELOPMENT & DEBUGGING
# ============================================
DEBUG=false
