# Backend Environment Configuration - Flask AI API Integration
# Copy this to .env and fill in the values

# ============================================================================
# Flask AI API Configuration
# ============================================================================
FLASK_API_URL=http://localhost:5000
FLASK_API_TIMEOUT=120000

# ============================================================================
# Existing Backend Configuration (keep your current values)
# ============================================================================
PORT=9999
JWT_SECRET=your_jwt_secret_here
DATABASE_URL=postgresql://user:password@localhost:5432/trustai
REDIS_URL=redis://localhost:6379

# Other existing environment variables...
