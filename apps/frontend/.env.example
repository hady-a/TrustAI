# Frontend Environment Configuration
#
# VITE_API_URL is a *relative* path by default so REST and WebSocket signalling
# both ride the same origin as the frontend. Vite's dev-server proxy
# (vite.config.ts) forwards `/api` and `/ws/interview` to the backend on :9999.
# This makes the app work transparently behind a Cloudflare tunnel or another
# LAN host without per-environment URL surgery.
#
# Override with an absolute URL only if you run a deployed backend on a
# different origin (e.g. `https://api.example.com/api`).
VITE_API_URL=/api
VITE_GOOGLE_CLIENT_ID=your-google-client-id
